<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.media.MediaView?>
<BorderPane prefHeight="650" prefWidth="1000" styleClass="root" stylesheets="@../css/workout.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx.Weight">

    <!-- ================= TOP BAR ================= -->

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-bar">
            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>

            <!-- Left side: fixed width to balance right side -->
            <HBox alignment="CENTER_LEFT" spacing="10" minWidth="220">
                <Button fx:id="backButton" onAction="#backToWeight" styleClass="back-button" text="← Back" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Center heading -->
            <VBox alignment="CENTER">
                <Label fx:id="categoryLabel" styleClass="title-label" text="WEIGHT TRAINING" />
                <Label fx:id="durationLabel" styleClass="subtitle-label" text="5 MIN WORKOUT" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Right side: same minWidth as left to keep heading truly centered -->
            <HBox alignment="CENTER_RIGHT" spacing="10" minWidth="220">
                <HBox fx:id="fireIconLabel" alignment="CENTER_LEFT" spacing="2">
                    <Label styleClass="fire-icon" text="🔥" />
                    <Label fx:id="caloriesLabel5min" styleClass="calories-label" text="Calories Burned: 0.0 cal" />
                </HBox>
            </HBox>

        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>

        <VBox alignment="CENTER" spacing="25" styleClass="center-container">
            <padding>
                <Insets bottom="30" left="40" right="40" top="30" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="30">

                <StackPane prefHeight="220" prefWidth="320" styleClass="image-card">
                    <MediaView fx:id = "weightlifting5minMediaView" fitHeight="220" fitWidth="320" preserveRatio = "false" />
                </StackPane>

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER" maxWidth="340" prefHeight="220" prefWidth="320" spacing="10" styleClass="exercise-card">

                    <Label style="-fx-font-weight: bold;" styleClass="small-heading" text="Quote Of the Day:" />

                    <Label fx:id="quoteLabel" styleClass="weight-quote" text="You don't get stress from doing work, you get stress when you avoid the work you are supposed to do." textAlignment="CENTER" wrapText="true" VBox.vgrow="ALWAYS" />

                </VBox>

            </HBox>

            <StackPane prefHeight="80" prefWidth="180" styleClass="timer-container">
                <Label fx:id="timerLabel5min" style="-fx-text-fill: #ef1133;" styleClass="timer-label" text="05:00" />
            </StackPane>

        </VBox>

    </center>

    <!-- ================= BOTTOM CONTROLS ================= -->
    <bottom>
        <HBox alignment="CENTER" spacing="30" styleClass="bottom-controls">
            <padding>
                <Insets bottom="30" left="20" right="20" top="20" />
            </padding>

            <Button fx:id="weight5minStartButton" style="-fx-background-color: #ef1133" onAction="#start5min" styleClass="control-button" text="START" />
            <Button fx:id="weight5minPauseButton" style="-fx-background-color: #ef1133" onAction="#pause5min" styleClass="control-button" text="PAUSE" />
            <Button fx:id="weight5minStopButton" style="-fx-background-color: #ef1133" onAction="#stop5min" styleClass="control-button" text="RESET" />
        </HBox>
    </bottom>

</BorderPane>
