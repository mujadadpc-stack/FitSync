<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import javafx.scene.media.MediaView?>
<BorderPane prefHeight="650" prefWidth="1000" styleClass="root" stylesheets="@../css/workout.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx.Cardio">

    <!-- ================= TOP BAR ================= -->

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-bar">




            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>

            <!-- Left side: fixed width to balance right side -->
            <HBox alignment="CENTER_LEFT" spacing="10" minWidth="266">
                <Button fx:id="backButton" onAction="#backToCardio" styleClass="back-button" text="← Back" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Center heading -->
            <VBox alignment="CENTER">
                <Label fx:id="categoryLabel" styleClass="title-label" text="CARDIO TRAINING" />
                <Label fx:id="durationLabel" styleClass="subtitle-label" text="WALKING" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Right side: same minWidth as left to keep heading truly centered -->
            <HBox alignment="CENTER_RIGHT" spacing="10" minWidth="220">
                <HBox fx:id="fireIconLabel" alignment="CENTER_LEFT" spacing="2">
                    <Label styleClass="fire-icon" text="🔥" />
                    <Label fx:id="walkingCaloriesLabel" styleClass="calories-label" text="Calories Burned: 0.0 cal" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="stepsLabel" styleClass="steps-label" text="Steps: 0" />
                </HBox>
            </HBox>

        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>

        <VBox alignment="CENTER" spacing="25" styleClass="center-container">
            <padding>
                <Insets bottom="30" left="40" right="40" top="30" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="30">

                <StackPane prefHeight="220" prefWidth="320" styleClass="image-card">
                    <MediaView fx:id="walkingMediaView" fitHeight="220" fitWidth="320" preserveRatio="false" />
                </StackPane>

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER" maxWidth="340" prefHeight="220" prefWidth="320" spacing="10" styleClass="exercise-card">

                    <Label style="-fx-font-weight: bold;" styleClass="small-heading" text="Quote Of the Day:" />

                    <Label fx:id="quoteLabel" styleClass="cardio-quote" text="You don't get stress from doing work, you get stress when you avoid the work you are supposed to do." textAlignment="CENTER" wrapText="true" VBox.vgrow="ALWAYS" />

                </VBox>

            </HBox>

            <StackPane prefHeight="80" prefWidth="180" styleClass="timer-container">
                <Label fx:id="walkingTimerLabel" style="-fx-text-fill: #ff7700;" styleClass="timer-label" text="00:00" />
            </StackPane>

        </VBox>

    </center>

    <!-- ================= BOTTOM CONTROLS ================= -->
    <bottom>
        <HBox alignment="CENTER" spacing="30" styleClass="bottom-controls">
            <padding>
                <Insets bottom="30" left="20" right="20" top="20" />
            </padding>

            <Button fx:id="walkingStartButton" onAction="#startWalking" style="-fx-background-color: #ff7700" styleClass="control-button" text="START" />
            <Button fx:id="walkingStopButton" onAction="#stopWalking" style="-fx-background-color: #ff7700" styleClass="control-button" text="STOP" />
        </HBox>
    </bottom>

</BorderPane>
