<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER" spacing="20" styleClass="progress-root" stylesheets="@../css/hello-view.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx.Progress">

   <VBox alignment="CENTER" spacing="20" styleClass="progress-panel">
      <children>
         <Label text="Your sweat is your fat crying 🔥" styleClass="progress-heading" />
         <PieChart fx:id="caloriesBurned" styleClass="progress-chart" />
      </children>
   </VBox>

   <VBox alignment="CENTER" spacing="20" styleClass="progress-panel">
      <children>
         <Label text="KEEP IT UP 🚶" styleClass="progress-heading" />
         <PieChart fx:id="stepsTaken" styleClass="progress-chart" />
      </children>
   </VBox>

</HBox>