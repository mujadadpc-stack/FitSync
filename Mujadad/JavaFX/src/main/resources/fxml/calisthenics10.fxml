<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>
<BorderPane prefHeight="650" prefWidth="1000" styleClass="root" stylesheets="@../css/workout.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx.Calisthenics">


    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-bar">
            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10" minWidth="220">
                <Button fx:id="backButton" onAction="#backToCalisthenics" styleClass="back-button" text="← Back" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER">
                <Label fx:id="categoryLabel" styleClass="title-label" text="CALISTHENICS TIME" />
                <Label fx:id="durationLabel" styleClass="subtitle-label" text="10 MIN WORKOUT" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT" spacing="10" minWidth="220">
                <HBox fx:id="fireIconLabel" alignment="CENTER_LEFT" spacing="2">
                    <Label styleClass="fire-icon" text="🔥" />
                    <Label fx:id="caloriesLabel10min" styleClass="calories-label" text="Calories Burned: 0.0 cal" />
                </HBox>
            </HBox>

        </HBox>
    </top>

    <center>

        <VBox alignment="CENTER" spacing="25" styleClass="center-container">
            <padding>
                <Insets bottom="30" left="40" right="40" top="30" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="30">

                <StackPane prefHeight="220" prefWidth="320" styleClass="image-card">
                    <MediaView fx:id="cali10minMediaView" fitHeight="220" fitWidth="320" preserveRatio="false" />
                </StackPane>

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER" maxWidth="340" prefHeight="220" prefWidth="320" spacing="10" styleClass="exercise-card">

                    <Label style="-fx-font-weight: bold;" styleClass="small-heading" text="Quote Of the Day:" />

                    <Label fx:id="quoteLabel" styleClass="cali-quote" text="Focus on being better than you used to be, not better than someone else." textAlignment="CENTER" wrapText="true" VBox.vgrow="ALWAYS" />

                </VBox>

            </HBox>

            <StackPane prefHeight="80" prefWidth="180" styleClass="timer-container">
                <Label fx:id="timerLabel10min" styleClass="timer-label" text="10:00" />
            </StackPane>

        </VBox>

    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="30" styleClass="bottom-controls">
            <padding>
                <Insets bottom="30" left="20" right="20" top="20" />
            </padding>

            <Button onAction="#start10min" fx:id="calisthenics10minStartButton" styleClass="control-button" text="START" />
            <Button onAction="#pause10min" fx:id="calisthenics10minPauseButton" styleClass="control-button" text="PAUSE" />
            <Button onAction="#stop10min" fx:id="calisthenics10minStopButton" styleClass="control-button" text="RESET" />
        </HBox>
    </bottom>

</BorderPane>

