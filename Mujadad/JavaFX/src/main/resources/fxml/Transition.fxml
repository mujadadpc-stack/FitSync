<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Arc?>

<StackPane styleClass="splash-root"
           maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx.Transition">
   <children>
      <Pane prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: black;" />
      <ImageView fx:id="bgImage" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
      <Arc fx:id="loadingArc" radiusX="30" radiusY="30" length="270" stroke="#4A90D9" strokeWidth="5" fill="TRANSPARENT" strokeLineCap="ROUND" layoutX="200" layoutY="330"/>
   </children>
</StackPane>
