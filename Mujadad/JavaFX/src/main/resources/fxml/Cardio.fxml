<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="cardioPane" stylesheets="/css/styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx.WorkoutController">

    <AnchorPane>
        <children>
            <ImageView fx:id="cardioImage" cache="true" fitHeight="700.0" fitWidth="1000.0" pickOnBounds="true" preserveRatio="false" style="-fx-smooth: 200;">
            </ImageView>
            <Label layoutX="34.0" layoutY="62.0" text="Cardio" textFill="WHITE">
                <font>
                    <Font name="Dubai Regular" size="36.0" />
                </font>
            </Label>
            <Button fx:id="cardio5min" layoutX="151.0" layoutY="180.0" mnemonicParsing="false" onAction="#onWalking" styleClass="duration-btn" text="Walking" />
            <Button fx:id="cardio10min" layoutX="274.0" layoutY="180.0" mnemonicParsing="false" onAction="#onRunning" styleClass="duration-btn" text="Running" />
            <Button fx:id="cardio20min" layoutX="400.0" layoutY="180.0" mnemonicParsing="false" onAction="#onSwimming" styleClass="duration-btn" text="Swimming" />
            <Label layoutX="34.0" layoutY="112.0" text="Select a workout duration" textFill="#cdcdcd">
                <font>
                    <Font name="Dubai Regular" size="16.0" />
                </font>
            </Label>
            <Button fx:id="backButton" layoutX="34.0" layoutY="14.0" mnemonicParsing="false" onAction="#backToDashboard" styleClass="back-btn" text="⬅ Back" />
        </children>

    </AnchorPane>
</StackPane>
